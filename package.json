{
  "name": "petlife-backend",
  "version": "1.0.0",
  "description": "PetLife backend API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "^6.4.1",
    "bcrypt": "^5.1.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^4.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "eslint": "^9.20.0",
    "form-data": "^4.0.5",
    "prisma": "^6.4.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
